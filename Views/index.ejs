<!DOCTYPE html>
<html>
<head>
  <title>Finance Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>

<div class="app-container">
   <table>
 
  <div class="topbar">
    <h1>Finance Dashboard</h1>

    <div class="top-actions">
      <select id="role">
        <option value="viewer">Viewer</option>
        <option value="admin">Admin</option>
      </select>

      <button style="background-color: blue;" id="darkToggle">🌙</button>
    </div>
  </div>

  <div class="cards">
    <div class="card income">
      <h2>₹ <span id="income"></span></h2>
      <p>Total Income</p>
    </div>

    <div class="card expense">
      <h2>₹ <span id="expense"></span></h2>
      <p>Total Expense</p>
    </div>

    <div class="card balance">
      <h2>₹ <span id="balance"></span></h2>
      <p>Balance</p>
    </div>
  </div>

  <div class="charts">
    <div class="chart-box">
      <h3>Spending Breakdown (Expenses)</h3>
      <canvas id="expenseChart"></canvas>
    </div>
  </div>

  <div class="insights">
    <h3>Insights</h3>
    <p id="insightText"></p>
  </div>
  <select id="sort">
  <option value="">Sort By</option>
  <option value="amount-high">Amount (High to Low)</option>
  <option value="amount-low">Amount (Low to High)</option>
  <option value="date-new">Date (Newest)</option>
  <option value="date-old">Date (Oldest)</option>
</select>
<span>Filter By</span>
<select id="filterType">
  
  <option value="all">All</option>
  <option value="income">Income</option>
  <option value="expense">Expense</option>
</select>

  <div class="controls">
    <input type="text" id="search" placeholder="Search transactions">

    <button class="export-btn" onclick="exportCSV()">
      ⬇ Export CSV
    </button>
  </div>

  <div id="adminForm" class="admin-only form-card">
    <h3>Add Transaction</h3>

    <input type="date" id="date">
    <input type="text" id="category" placeholder="Category (Food, Salary)">
    <input type="number" id="amount" placeholder="Amount">

    <select id="type">
      <option value="income">Income</option>
      <option value="expense">Expense</option>
    </select>

    <button style="background-color: blue;" onclick="addTransaction()"> Add Transaction</button>
  </div>

  <div class="table-container">
    <h3>Transactions</h3>

    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Amount</th>
          <th>Category</th>
          <th>Type</th>
          <th class="admin-only">Action</th>
        </tr>
      </thead>

      <tbody id="tableBody">
        <% transactions.forEach(t => { %>
          <tr>
            <td><%= t.date %></td>
            <td>₹<%= t.amount %></td>
            <td><%= t.category %></td>
            <td><%= t.type %></td>
            <td class="admin-only">
              <button style="background: red;" onclick="deleteRow(this)">Delete</button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</div>

<script>

  const transactions = JSON.parse('<%- JSON.stringify(transactions) %>');


</script>

<script src="/js/script.js"></script>
</table>
</body>
</html>
